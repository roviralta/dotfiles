# ============================================================
# i3 WM — Nordic Minimalist (EndeavourOS)
# Author: Rovi
# ============================================================

# -----------------------------
# Mod key (Windows key)
set $mod Mod4

# Font
font pango:JetBrains Mono 10

# Terminal
set $terminal alacritty

# Use internal laptop speakers by default
exec --no-startup-id pactl set-default-sink alsa_output.pci-0000_00_1f.3-platform-skl_hda_dsp_generic.HiFi__Speaker__sink

# -----------------------------
# Keyboard layout (Catalan Spanish)
exec_always --no-startup-id setxkbmap -layout es -variant cat

# -----------------------------
# Resolution
exec_always --no-startup-id xrdb -merge ~/.Xresources


# -----------------------------
# Gaps & borders
gaps inner 2
gaps outer 2
smart_gaps on
default_border pixel 2
hide_edge_borders smart

# -----------------------------
# Nordic color palette
set $bg            #2E3440
set $bg-alt        #3B4252
set $fg            #D8DEE9
set $fg-alt        #E5E9F0
set $blue          #81A1C1
set $cyan          #88C0D0
set $green         #A3BE8C
set $red           #BF616A
set $yellow        #EBCB8B
set $purple        #B48EAD

# -----------------------------
# Window colors
client.focused          $blue    $blue    $fg     $blue
client.unfocused        $bg-alt  $bg-alt  $fg-alt $bg-alt
client.focused_inactive $bg-alt  $bg-alt  $fg-alt $bg-alt
client.urgent           $red     $red     $fg     $red
client.placeholder      $bg      $bg      $fg     $bg

client.background $bg

# -----------------------------
# Keybindings — basics
bindsym $mod+Return exec $terminal
bindsym $mod+d exec rofi -show drun -theme ~/.config/rofi/config.rasi
bindsym $mod+q kill
bindsym $mod+Shift+r restart
bindsym $mod+Shift+e exec "i3-nagbar -t warning -m 'Exit i3?' -b 'Yes' 'i3-msg exit'"
bindsym $mod+b exec firefox
bindsym $mod+c exec code
bindsym $mod+s exec spotify
bindsym $mod+k exec spectacle -r

# Lock screen
bindsym $mod+l exec --no-startup-id betterlockscreen -l dim
# Shutdown
bindsym $mod+Shift+q exec --no-startup-id systemctl poweroff
# Reboot
bindsym $mod+Shift+Ctrl+r exec --no-startup-id systemctl reboot

# -----------------------------
# Focus movement
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# Move windows
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# -----------------------------
# Layouts
bindsym $mod+v split v
bindsym $mod+h split h
bindsym $mod+f fullscreen toggle
bindsym $mod+Shift+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

# Floating
bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle

# -----------------------------
# Workspaces
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"

bindsym $mod+1 workspace $ws1
bindsym $mod+2 workspace $ws2
bindsym $mod+3 workspace $ws3
bindsym $mod+4 workspace $ws4
bindsym $mod+5 workspace $ws5
bindsym $mod+6 workspace $ws6
bindsym $mod+7 workspace $ws7
bindsym $mod+8 workspace $ws8

bindsym $mod+Shift+1 move container to workspace $ws1
bindsym $mod+Shift+2 move container to workspace $ws2
bindsym $mod+Shift+3 move container to workspace $ws3
bindsym $mod+Shift+4 move container to workspace $ws4
bindsym $mod+Shift+5 move container to workspace $ws5
bindsym $mod+Shift+6 move container to workspace $ws6
bindsym $mod+Shift+7 move container to workspace $ws7
bindsym $mod+Shift+8 move container to workspace $ws8

# -----------------------------
# Multimedia keys (laptop)
# Multimedia keys
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +2%
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -2%
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle

bindsym XF86MonBrightnessUp exec --no-startup-id brightnessctl set +5%
bindsym XF86MonBrightnessDown exec --no-startup-id brightnessctl set 5%-

# -----------------------------
# Startup applications
exec_always --no-startup-id feh --bg-fill /home/rovi/wallpapers/nordic.png
exec_always --no-startup-id killall -q picom; picom --config ~/.config/picom/picom.conf
exec_always --no-startup-id ~/.config/polybar/launch.sh
exec --no-startup-id xsettingsd
exec --no-startup-id dunst

exec --no-startup-id batsignal -b -w 15 -c 10 -d 5

# Multi-monitor
exec --no-startup-id autorandr --change
# -----------------------------
# Disable titlebars for cleanliness
for_window [class=".*"] border pixel 2


